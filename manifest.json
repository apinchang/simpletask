{
  "manifest_version": 3,
  "name": "简单任务",
  "version": "1.0",
  "description": "简单任务管理插件",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/tasks-16.png",
    "32": "icons/tasks-32.png",
    "48": "icons/tasks-48.png",
    "128": "icons/tasks-128.png"
  }
}
